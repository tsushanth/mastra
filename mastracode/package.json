{
  "name": "mastracode",
  "version": "0.29.0-alpha.2",
  "description": "",
  "type": "module",
  "files": [
    "dist",
    "!dist/web",
    "CHANGELOG.md"
  ],
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "mastracode"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mastracode": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./tui": {
      "import": {
        "types": "./dist/tui/index.d.ts",
        "default": "./dist/tui.js"
      },
      "require": {
        "types": "./dist/tui/index.d.ts",
        "default": "./dist/tui.cjs"
      }
    },
    "./acp": {
      "import": {
        "types": "./dist/acp.d.ts",
        "default": "./dist/acp.js"
      },
      "require": {
        "types": "./dist/acp.d.ts",
        "default": "./dist/acp.cjs"
      }
    },
    "./headless": {
      "import": {
        "types": "./dist/headless/index.d.ts",
        "default": "./dist/headless.js"
      },
      "require": {
        "types": "./dist/headless/index.d.ts",
        "default": "./dist/headless.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin.d.ts",
        "default": "./dist/plugin.js"
      },
      "require": {
        "types": "./dist/plugin.d.ts",
        "default": "./dist/plugin.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "cli": "tsx src/main.ts",
    "check": "tsc --noEmit && pnpm check:ui",
    "check:ui": "tsc --noEmit -p src/web/ui/tsconfig.json",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "web:dev": "concurrently --kill-others-on-fail --names server,ui \"PORT=4111 mastra dev --dir src/mastra --env src/web/.env\" \"vite --config src/web/vite.config.ts\"",
    "web:dev:github": "pnpm db:up && pnpm web:dev",
    "web:ui:build": "vite --config src/web/vite.config.ts build",
    "web:test": "vitest run --config e2e/web/vitest.config.ts",
    "web:ui:test": "vitest run --config e2e/web-ui/vitest.config.ts",
    "build:lib": "tsup --silent --config tsup.config.ts",
    "prepack": "tsx ../scripts/generate-package-docs.ts",
    "test": "vitest",
    "lint": "eslint .",
    "e2e:list": "tsx e2e-list.ts",
    "e2e:smoke": "vitest run --config e2e/vitest.shards.config.ts",
    "e2e:test": "MC_E2E_VITEST_SCENARIOS=all vitest run --config e2e/vitest.shards.config.ts",
    "web:build": "mastra build --dir src/mastra",
    "web:start": "mastra start --env src/web/.env"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@ai-sdk/amazon-bedrock": "^3.0.102",
    "@ai-sdk/anthropic": "^3.0.82",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@aws-sdk/credential-providers": "^3.864.0",
    "@ast-grep/napi": "^0.42.0",
    "@earendil-works/pi-tui": "^0.79.4",
    "@hono/node-server": "^1.19.11",
    "@mastra/agent-browser": "workspace:*",
    "@mastra/auth-workos": "workspace:*",
    "@mastra/core": "workspace:*",
    "@mastra/duckdb": "workspace:*",
    "@mastra/fastembed": "workspace:*",
    "@mastra/github-signals": "workspace:*",
    "@mastra/hono": "workspace:*",
    "@mastra/libsql": "workspace:*",
    "@mastra/mcp": "workspace:*",
    "@mastra/memory": "workspace:*",
    "@mastra/client-js": "workspace:*",
    "@mastra/observability": "workspace:*",
    "@mastra/pg": "workspace:*",
    "@mastra/playground-ui": "workspace:*",
    "@mastra/railway": "workspace:*",
    "@mastra/react": "workspace:*",
    "@mastra/schema-compat": "workspace:*",
    "@mastra/server": "workspace:*",
    "@mastra/stagehand": "workspace:*",
    "@mastra/tavily": "workspace:*",
    "@mastra/voice-deepgram": "workspace:*",
    "@mastra/voice-openai": "workspace:*",
    "@octokit/auth-app": "^8.0.0",
    "@octokit/rest": "^22.0.1",
    "@tanstack/react-query": "^5.90.21",
    "@tursodatabase/api": "2.0.4",
    "ai": "^6.0.176",
    "chalk": "^5.5.0",
    "cli-highlight": "^2.1.11",
    "drizzle-orm": "^0.45.0",
    "execa": "^9.6.1",
    "fastest-levenshtein": "^1.0.16",
    "hono": "^4.12.8",
    "lucide-react": "^0.474.0",
    "partial-json": "^0.1.7",
    "pg": "^8.21.0",
    "posthog-node": "^5.37.0",
    "strip-ansi": "^7.2.0",
    "tokenx": "^1.3.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@copilotkit/aimock": "^1.29.0",
    "@internal/lint": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "@mastra/client-js": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "4.2.2",
    "mastra": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "22.19.21",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "@xterm/headless": "6.0.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.0",
    "eslint": "^10.4.1",
    "jsdom": "^26.1.0",
    "marked": "^15.0.0",
    "msw": "^2.12.11",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.13.1",
    "shiki": "^1.29.2",
    "tailwindcss": "4.2.2",
    "tsup": "^8.5.1",
    "tsx": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
